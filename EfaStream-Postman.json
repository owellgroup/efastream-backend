              "raw": "{\n  \"email\": \"partner@studio.com\",\n  \"password\": \"Partner@123\",\n  \"companyName\": \"Studio X\",\n  \"contactPerson\": \"Jane\",\n  \"phone\": \"+1234567890\"\n}"
            },
