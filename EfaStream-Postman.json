            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/content/stream/1"
          }
        },
        {
          "name": "Record download",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/content/download/1"
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get plans (public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subscriptions/plans"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": 1,\n  \"amount\": 9.99,\n  \"currency\": \"USD\",\n  \"returnUrl\": \"http://localhost:3000/subscription/success\",\n  \"cancelUrl\": \"http://localhost:3000/subscription/cancel\"\n}"
            },
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Verify payment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/verify?token=stripe_mock_1"
          }
        },
        {
          "name": "Payment history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/payments/history"
          }
        }
      ]
    },
    {
      "name": "Hero",
